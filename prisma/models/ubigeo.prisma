model Department {
  id   String @id
  name String

  provinces Province[]
  establishments Establishment[] @relation("EstablishmentDepartment")

  @@map("departments")
}

model Province {
  id           String @id
  departmentId String
  name         String

  department Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  districts  District[]
  establishments Establishment[] @relation("EstablishmentProvince")

  @@index([departmentId])
  @@map("provinces")
}

model District {
  id         String @id
  provinceId String
  name       String

  province Province @relation(fields: [provinceId], references: [id], onDelete: Restrict)
  establishments Establishment[] @relation("EstablishmentDistrict")

  @@index([provinceId])
  @@map("districts")
}
