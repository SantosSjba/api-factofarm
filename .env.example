# Copia este archivo como `.env` y ajusta la contraseña de PostgreSQL.
# La URL también la usa Prisma Migrate vía prisma.config.ts (no está en schema.prisma).
DATABASE_URL="postgresql://postgres:CAMBIA_AQUI_TU_PASSWORD@localhost:5432/postgres?schema=public"

# Opcional
# PORT=3000
# NODE_ENV=development
#
# Con el API en marcha (prefijo global /api):
# Documentación Scalar → http://localhost:3000/api/docs
# OpenAPI JSON → http://localhost:3000/api/openapi.json
